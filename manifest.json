{
  "manifest_version": 3,
  "name": "OniAnime Tracker",
  "version": "3.0",
  "description": "Automatikusan k\u00f6veti a megn\u00e9zett anime r\u00e9szeket az onianime.hu-n",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://onianime.hu/*",
    "https://uctzsndnlmpsmniufrzg.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://onianime.hu/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OniAnime Tracker"
  }
}
