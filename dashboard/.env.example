# Cloudflare Pages -> Settings -> Environment Variables
# Ezeket kell beállítani a Cloudflare dashboardon!

# Supabase kapcsolat
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Extension token - ezt kell beírni a Chrome extensionbe is
EXTENSION_API_TOKEN=oni_valami_titkos_token

# Admin bejelentkezés (opcionális - ha nincs USERS_JSON)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=valami_eros_jelszo

# Több felhasználó (opcionális, JSON formátum):
# USERS_JSON=[{"username":"admin","password":"jelszo","role":"superadmin","displayName":"Admin"}]
